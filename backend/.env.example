NODE_ENV=production
PORT=3000
FRONTEND_ORIGIN=http://localhost:3000

DATABASE_PATH=/data/storytelling.sqlite
BACKUP_DIR=/data/backups

# قصه — GapGPT (یا OpenAI رسمی)
STORY_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.gapgpt.app/v1
OPENAI_MODEL=gpt-4o-mini

# TTS — ivira (آواشو / ویرا) | elevenlabs | mock (تست محلی) | openai
TTS_PROVIDER=ivira

# Ivira Avasho TTS — https://api.ivira.ai/panel/service/serviceDetail?serviceID=97192615-41ab-4b39-bd7b-324e353b9448
IVIRA_TOKEN=
IVIRA_BASE_URL=https://partai.gw.isahab.ir
IVIRA_SERVICE_ID=97192615-41ab-4b39-bd7b-324e353b9448
IVIRA_SPEAKER=6
IVIRA_TIMEOUT_MS=60000
IVIRA_CONNECT_TIMEOUT_MS=30000
# در صورت فیلتر بودن gw.isahab.ir — آدرس پروکسی HTTP/S (مثلاً VPN ایران)
# IVIRA_PROXY_URL=http://127.0.0.1:1080
# اگر ویرا در دسترس نبود، با OpenAI/GapGPT TTS جایگزین شود (true/false)
IVIRA_FALLBACK_OPENAI=false

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# OpenAI TTS (فقط اگر TTS_PROVIDER=openai)
OPENAI_TTS_API_KEY=
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

CUSTOM_VOICE_ENABLED=false

AUDIO_STORAGE_DIR=/data/audio
# صدای پس‌زمینه آرام در تولید صوت قصه (وقتی از UI فعال شود)
STORY_BACKGROUND_AUDIO_PATH=../frontend/images/audio/source.mp3
STORY_BACKGROUND_VOLUME=0.14
VOICE_UPLOAD_DIR=/data/voice-uploads

MAX_AUDIO_UPLOAD_MB=10

PROMPT_VERSION=v1.0.0

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

ADMIN_TOKEN=change-this-admin-token

JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRES_IN_SEC=604800

LOG_LEVEL=info
